# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/your-project/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google AI / Gemini (optional — exposed to the client; restrict key by HTTP referrer in Google Cloud)
# Get a key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key

# App Configuration (Optional)
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=BlackBox Tech

# Contact form → your inbox (Web3Forms: https://web3forms.com — free tier)
VITE_WEB3FORMS_ACCESS_KEY=
